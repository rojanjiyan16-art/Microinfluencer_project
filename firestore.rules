rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. User Validation Blueprint
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'displayName', 'waNumber', 'location', 'createdAt'])
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() > 0
        && data.role in ['umkm', 'influencer']
        && data.waNumber is string && data.waNumber.size() >= 10
        && data.location is string
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isSignedIn(); // Allow reading profiles for collaboration
      allow list: if isSignedIn() && (resource.data.role == 'influencer' || isOwner(userId)); // Browsing influencers
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Prevent changing immutable fields
        incoming().role == existing().role && 
        incoming().uid == existing().uid &&
        incoming().email == existing().email &&
        incoming().createdAt == existing().createdAt
      );
    }
  }
}
